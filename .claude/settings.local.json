{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(test:*)",
      "mcp__web-reader__webReader",
      "Bash(pip install:*)",
      "Bash(python:*)",
      "Bash(git init:*)",
      "Bash(git add:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -m ahahooh.hook_handler"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m ahahooh.hook_handler --stop"
          }
        ]
      }
    ]
  }
}
